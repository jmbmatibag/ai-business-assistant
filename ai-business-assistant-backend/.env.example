# PostgreSQL credentials (used by docker-compose and the app)
POSTGRES_USER=aiba
POSTGRES_PASSWORD=aiba_dev_password
POSTGRES_DB=aiba

# SQLAlchemy connection string.
# From the host (running migrations/seed locally) use localhost:5434
# (5434 avoids clashing with a locally-installed PostgreSQL on 5432).
# Inside the docker network the host is the service name "db" on port 5432.
DATABASE_URL=postgresql+psycopg2://aiba:aiba_dev_password@localhost:5434/aiba

# Auth (Phase 2)
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI engine (Phase 4)
ANTHROPIC_API_KEY=

# Encryption key for stored external data-source passwords (Fernet).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If blank, a key is derived from JWT_SECRET_KEY (fine for dev, NOT for production).
FERNET_KEY=
